# Normalize line endings for all text files
* text=auto

# Unity YAML serialized files — keep as text for diff/merge
*.unity        text eol=lf merge=unityyamlmerge
*.prefab       text eol=lf merge=unityyamlmerge
*.asset        text eol=lf merge=unityyamlmerge
*.mat          text eol=lf merge=unityyamlmerge
*.meta         text eol=lf
*.controller   text eol=lf merge=unityyamlmerge
*.anim         text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf
*.physicsMaterial2D  text eol=lf
*.playable     text eol=lf
*.mask         text eol=lf
*.brush        text eol=lf
*.flare        text eol=lf
*.fontsettings text eol=lf
*.guiskin      text eol=lf
*.lighting     text eol=lf
*.preset       text eol=lf
*.renderTexture text eol=lf
*.spriteatlas  text eol=lf
*.terrainlayer text eol=lf

# Code
*.cs           text eol=lf diff=csharp
*.shader       text eol=lf
*.hlsl         text eol=lf
*.cginc        text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.txt          text eol=lf
*.md           text eol=lf
*.asmdef       text eol=lf
*.asmref       text eol=lf
*.inputactions text eol=lf

# ── Git LFS: binary assets ──────────────────────────────────────────────────

